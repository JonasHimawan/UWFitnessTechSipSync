/*
 * SipSync HX711 Load Cell Calibration & Reading
 * Board: Arduino Mega
 *
 * Wiring:
 *   HX711 DOUT → 2
 *   HX711 SCK  → 3
 *   HX711 VCC  → 5V
 *   HX711 GND  → GND
 *
 * How to use:
 *   1. Upload this sketch
 *   2. Open Serial Monitor at 115200 baud
 *   3. Follow the on-screen menu
 *   4. Calibrate first (option 1), then use live reading (option 3)
 *
 * Library required: "HX711" by bogde
 *   Install via: Arduino IDE → Library Manager → search "HX711" → install by bogde
 */

#include <HX711.h>
#include <EEPROM.h>

// ─── PIN DEFINITIONS ───────────────────────────────────────────
const int HX711_DOUT_PIN = 2;
const int HX711_SCK_PIN  = 3;

// ─── OBJECTS ────────────────────────────────────────────────────
HX711 scale;

// ─── CALIBRATION STATE ──────────────────────────────────────────
float calibrationFactor = 1.0;
long  zeroOffset        = 0;
bool  isCalibrated      = false;

// ─── SETTINGS ───────────────────────────────────────────────────
const int   READ_SAMPLES     = 10;
const float SIP_THRESHOLD_G  = 15.0;
const int   STABLE_READINGS  = 5;

// ─── EEPROM STORAGE ─────────────────────────────────────────────
struct CalibrationData {
  float calibrationFactor;
  long zeroOffset;
  bool calibrated;
};

const int EEPROM_ADDR = 0;

// ─── FORWARD DECLARATIONS ───────────────────────────────────────
void showMenu();
void runCalibration();
void verifyCalibration();
void liveReading();
void resetCalibration();
void saveCalibration();
bool loadCalibration();
void showRawValues();
void waitForSerial();
char waitForSerialChar();
float readFloatFromSerial();
String readStringFromSerial();

// ════════════════════════════════════════════════════════════════
//  SETUP
// ════════════════════════════════════════════════════════════════
void setup() {
  Serial.begin(115200);
  delay(2000);

  Serial.println("╔══════════════════════════════════════╗");
  Serial.println("║   SipSync HX711 Calibration Tool     ║");
  Serial.println("║   Board: Arduino Mega                ║");
  Serial.println("╚══════════════════════════════════════╝");
  Serial.println();

  scale.begin(HX711_DOUT_PIN, HX711_SCK_PIN);

  if (!scale.wait_ready_timeout(2000)) {
    Serial.println("ERROR: HX711 not detected!");
    Serial.println("Check wiring:");
    Serial.println("  DOUT → 2");
    Serial.println("  SCK  → 3");
    Serial.println("  VCC  → 5V");
    Serial.println("  GND  → GND");
    while (true) { delay(1000); }
  }
  Serial.println("HX711 detected ✓");

  if (loadCalibration()) {
    Serial.println("Saved calibration loaded ✓");
    Serial.print("  Calibration factor: ");
    Serial.println(calibrationFactor, 4);
    Serial.print("  Zero offset: ");
    Serial.println(zeroOffset);
    isCalibrated = true;
  } else {
    Serial.println("No saved calibration found — please calibrate first.");
  }

  Serial.println();
  showMenu();
}

// ════════════════════════════════════════════════════════════════
//  LOOP
// ════════════════════════════════════════════════════════════════
void loop() {
  if (Serial.available()) {
    char cmd = Serial.read();
    while (Serial.available()) Serial.read();

    switch (cmd) {
      case '1': runCalibration();    break;
      case '2': verifyCalibration(); break;
      case '3': liveReading();       break;
      case '4': resetCalibration();  break;
      case '5': showRawValues();     break;
      default:  showMenu();          break;
    }
  }
}

// ════════════════════════════════════════════════════════════════
//  MENU
// ════════════════════════════════════════════════════════════════
void showMenu() {
  Serial.println("──────────── MENU ────────────");
  Serial.println("  1 → Calibrate (guided)");
  Serial.println("  2 → Verify calibration");
  Serial.println("  3 → Live weight reading");
  Serial.println("  4 → Reset calibration");
  Serial.println("  5 → Raw ADC values (debug)");
  Serial.println("──────────────────────────────");
  Serial.println("Send a number (1-5):");
}

// ════════════════════════════════════════════════════════════════
//  1. GUIDED CALIBRATION
// ════════════════════════════════════════════════════════════════
void runCalibration() {
  Serial.println();
  Serial.println("═══ CALIBRATION START ═══");
  Serial.println();

  Serial.println("STEP 1: Remove ALL weight from the load cell.");
  Serial.println("        Nothing on it — no bottle, no weights.");
  Serial.println("        Send any key when ready...");
  waitForSerial();

  Serial.println("Reading zero point (averaging 20 samples)...");
  scale.set_scale(1.0);
  scale.tare(20);
  zeroOffset = scale.get_offset();
  Serial.print("  Zero offset (raw): ");
  Serial.println(zeroOffset);
  Serial.println("  Zero set ✓");
  Serial.println();

  Serial.println("STEP 2: Place a KNOWN weight on the load cell.");
  Serial.println("        Type the weight in grams (e.g. 100)");
  Serial.println("        and press Enter:");

  float knownWeight = readFloatFromSerial();
  if (knownWeight <= 0) {
    Serial.println("ERROR: Weight must be > 0. Calibration aborted.");
    showMenu();
    return;
  }

  Serial.print("Reading with ");
  Serial.print(knownWeight, 1);
  Serial.println("g on the cell (averaging 20 samples)...");

  long rawWithWeight = scale.get_units(20);

  if (rawWithWeight == 0) {
    Serial.println("ERROR: Raw reading is 0 — something is wrong.");
    Serial.println("Check that the weight is actually on the load cell.");
    showMenu();
    return;
  }

  calibrationFactor = (float)rawWithWeight / knownWeight;

  Serial.println();
  Serial.println("═══ CALIBRATION RESULTS ═══");
  Serial.print("  Known weight:       ");
  Serial.print(knownWeight, 1);
  Serial.println(" g");
  Serial.print("  Raw reading:        ");
  Serial.println(rawWithWeight);
  Serial.print("  Calibration factor: ");
  Serial.println(calibrationFactor, 4);

  scale.set_scale(calibrationFactor);
  scale.set_offset(zeroOffset);

  Serial.println();
  Serial.println("Verifying — leave the weight on...");
  float measured = scale.get_units(10);
  Serial.print("  Measured: ");
  Serial.print(measured, 1);
  Serial.print(" g  (expected ");
  Serial.print(knownWeight, 1);
  Serial.println(" g)");

  float errorPct = abs(measured - knownWeight) / knownWeight * 100.0;
  Serial.print("  Error: ");
  Serial.print(errorPct, 1);
  Serial.println("%");

  if (errorPct < 2.0) {
    Serial.println("  Accuracy: EXCELLENT ✓");
  } else if (errorPct < 5.0) {
    Serial.println("  Accuracy: GOOD ✓");
  } else {
    Serial.println("  Accuracy: POOR — consider recalibrating");
  }

  Serial.println();
  Serial.println("Save this calibration? (y/n):");
  char c = waitForSerialChar();
  if (c == 'y' || c == 'Y') {
    saveCalibration();
    isCalibrated = true;
    Serial.println("Calibration saved to EEPROM ✓");
  } else {
    Serial.println("Not saved (will be lost if recalibrated/reset).");
    isCalibrated = true;
  }

  Serial.println();
  showMenu();
}

// ════════════════════════════════════════════════════════════════
//  2. VERIFY WITH MULTIPLE WEIGHTS
// ════════════════════════════════════════════════════════════════
void verifyCalibration() {
  if (!isCalibrated) {
    Serial.println("Not calibrated yet! Run option 1 first.");
    showMenu();
    return;
  }

  Serial.println();
  Serial.println("═══ VERIFICATION MODE ═══");
  Serial.println("Place different known weights to check accuracy.");
  Serial.println("Type the expected weight in grams, or 'q' to quit.");
  Serial.println();

  scale.set_scale(calibrationFactor);
  scale.set_offset(zeroOffset);

  while (true) {
    Serial.println("Enter expected weight (grams), or 'q' to quit:");

    String input = readStringFromSerial();
    if (input == "q" || input == "Q") break;

    float expected = input.toFloat();
    if (expected <= 0) {
      Serial.println("Invalid — enter a positive number.");
      continue;
    }

    Serial.print("Reading (10 samples)... ");
    float measured = scale.get_units(10);
    float error = abs(measured - expected);
    float errorPct = error / expected * 100.0;

    Serial.print("Measured: ");
    Serial.print(measured, 1);
    Serial.print(" g | Expected: ");
    Serial.print(expected, 1);
    Serial.print(" g | Error: ");
    Serial.print(error, 1);
    Serial.print(" g (");
    Serial.print(errorPct, 1);
    Serial.println("%)");
    Serial.println();
  }

  Serial.println();
  showMenu();
}

// ════════════════════════════════════════════════════════════════
//  3. LIVE WEIGHT READING
// ════════════════════════════════════════════════════════════════
void liveReading() {
  if (!isCalibrated) {
    Serial.println("Not calibrated yet! Run option 1 first.");
    showMenu();
    return;
  }

  Serial.println();
  Serial.println("═══ LIVE READING MODE ═══");
  Serial.println("Showing weight in real-time. Send any key to stop.");
  Serial.println("Sip detection active (threshold: " + String(SIP_THRESHOLD_G, 0) + "g drop)");
  Serial.println();

  scale.set_scale(calibrationFactor);
  scale.set_offset(zeroOffset);

  float previousWeight = scale.get_units(READ_SAMPLES);
  float stableWeight = previousWeight;
  int sipCount = 0;
  int stableCount = 0;

  bool live = true;

  while (live) {
    if (Serial.available()) {
      char curr = waitForSerialChar();
      if (curr == 'q') {
        live = false;
      }
    }

    float currentWeight = scale.get_units(READ_SAMPLES);
    float delta = currentWeight - stableWeight;

    if (abs(currentWeight - previousWeight) < 3.0) {
      stableCount++;
    } else {
      stableCount = 0;
    }

    if (stableCount >= STABLE_READINGS && delta < -SIP_THRESHOLD_G) {
      sipCount++;
      float sipAmount = abs(delta);
      Serial.println();
      Serial.print("  *** SIP DETECTED *** (~");
      Serial.print(sipAmount, 0);
      Serial.print("g = ~");
      Serial.print(sipAmount, 0);
      Serial.println("mL)");
      Serial.println();
      stableWeight = currentWeight;
    }

    Serial.print("Weight: ");
    Serial.print(currentWeight, 1);
    Serial.print(" g  |  Sips: ");
    Serial.print(sipCount);
    Serial.print("  |  Delta: ");
    Serial.print(delta, 1);
    Serial.println(" g");

    previousWeight = currentWeight;
    delay(500);
  }

  if (live == false) {
    Serial.println();
    Serial.println("Live reading stopped.");
    showMenu();
  }
}

// ════════════════════════════════════════════════════════════════
//  4. RESET CALIBRATION
// ════════════════════════════════════════════════════════════════
void resetCalibration() {
  Serial.println("Are you sure? This deletes saved calibration. (y/n):");
  char c = waitForSerialChar();
  if (c == 'y' || c == 'Y') {
    CalibrationData emptyData = {1.0, 0, false};
    EEPROM.put(EEPROM_ADDR, emptyData);

    calibrationFactor = 1.0;
    zeroOffset = 0;
    isCalibrated = false;
    scale.set_scale(1.0);
    scale.set_offset(0);

    Serial.println("Calibration cleared ✓");
  } else {
    Serial.println("Cancelled.");
  }
  showMenu();
}

// ════════════════════════════════════════════════════════════════
//  5. RAW ADC VALUES
// ════════════════════════════════════════════════════════════════
void showRawValues() {
  Serial.println();
  Serial.println("═══ RAW ADC DEBUG ═══");
  Serial.println("Showing raw HX711 values. Send any key to stop.");
  Serial.println();

  scale.set_scale(1.0);
  scale.set_offset(0);

  while (true) {
    if (Serial.available()) {
      while (Serial.available()) Serial.read();
      break;
    }

    long rawValue = scale.read_average(5);
    Serial.print("Raw: ");
    Serial.print(rawValue);
    Serial.print("  |  Avg(10): ");
    Serial.println(scale.read_average(10));

    delay(500);
  }

  if (isCalibrated) {
    scale.set_scale(calibrationFactor);
    scale.set_offset(zeroOffset);
  }

  Serial.println();
  showMenu();
}

// ════════════════════════════════════════════════════════════════
//  STORAGE: Save/Load calibration to EEPROM
// ════════════════════════════════════════════════════════════════
void saveCalibration() {
  CalibrationData data = { calibrationFactor, zeroOffset, true };
  EEPROM.put(EEPROM_ADDR, data);
}

bool loadCalibration() {
  CalibrationData data;
  EEPROM.get(EEPROM_ADDR, data);

  if (data.calibrated) {
    calibrationFactor = data.calibrationFactor;
    zeroOffset = data.zeroOffset;
    scale.set_scale(calibrationFactor);
    scale.set_offset(zeroOffset);
    return true;
  }
  return false;
}

// ════════════════════════════════════════════════════════════════
//  SERIAL HELPERS
// ════════════════════════════════════════════════════════════════
void waitForSerial() {
  while (!Serial.available()) { delay(50); }
  while (Serial.available()) Serial.read();
}

char waitForSerialChar() {
  while (!Serial.available()) { delay(50); }
  char c = Serial.read();
  while (Serial.available()) Serial.read();
  return c;
}

float readFloatFromSerial() {
  String input = readStringFromSerial();
  return input.toFloat();
}

String readStringFromSerial() {
  while (!Serial.available()) { delay(50); }
  String input = Serial.readStringUntil('\n');
  input.trim();
  return input;
}
